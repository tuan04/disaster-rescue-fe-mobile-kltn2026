.chat/
.cursor/
.continue/

# 4. Định dạng file nặng & ảnh (AI không cần đọc pixel ảnh)
assets/
*.png
*.jpg
*.jpeg
*.svg
*.gif
*.mp4
*.mp3
*.ttf
*.woff

# 5. File build tĩnh & Log rác
dist/
build/
*.log
